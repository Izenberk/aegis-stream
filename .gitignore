# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (Safe to ignore since we use Go Modules)
vendor/

# IDE and OS files
.vscode/
.DS_Store

# Environment files (may contain secrets)
.env
.env.*

# Stray binaries built outside bin/
/server
/stress
/dashboard/api/api
